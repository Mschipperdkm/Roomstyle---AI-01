# OpenAI API Key — voor het genereren van kamerafbeeldingen via DALL-E 3
# Haal deze op via: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optioneel: Supabase voor lead opslag
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx

# Optioneel: model override (standaard: dall-e-3)
# OPENAI_IMAGE_MODEL=dall-e-3
